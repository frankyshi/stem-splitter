# YouTube import: use browser cookies for download (often required for 403 / SABR).
# Set to the browser you are signed into (e.g. chrome, firefox). Safari may fail on macOS due to permissions.
YTDLP_COOKIES_FROM_BROWSER=chrome

# Optional: set to true/1 for full yt-dlp stdout/stderr in logs
# YTDLP_DEBUG=false
